<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= product.name %> — Details</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body class="bg-light">

  <nav class="navbar navbar-light bg-white shadow-sm mb-5">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/home">
        <i class="bi bi-arrow-left me-2"></i>Back to Shop
      </a>
    </div>
  </nav>

  <div class="container py-5">
    <div class="row g-5">
      <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
          <img src="<%= product.image %>" class="img-fluid" alt="<%= product.name %>">
        </div>
      </div>

      <div class="col-md-6">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/home">Home</a></li>
            <li class="breadcrumb-item active"><%= product.category ? product.category.name : 'Product' %></li>
          </ol>
        </nav>

        <h1 class="display-5 fw-bold mb-3"><%= product.name %></h1>
        <!-- <h2 class="text-success fw-bold mb-4">₹<%= product.price %></h2> -->

        <div class="mb-4">
          <h5 class="fw-bold">Description</h5>
          <p class="text-muted leading-relaxed"><%= product.description %></p>
        </div>

        <div class="row mb-4">
          <div class="col-6">
            <p class="mb-1 text-muted small">Status</p>
            <span class="badge bg-success">In Stock</span>
          </div>
          <div class="col-6">
            <p class="mb-1 text-muted small">Delivery</p>
            <p class="fw-bold mb-0">2-4 Business Days</p>
          </div>
        </div>

        <hr class="my-4">

        <div class="d-grid gap-3">
          <button class="btn btn-primary btn-lg py-3 fw-bold">
            <i class="bi bi-cart-plus me-2"></i>Add to Cart
          </button>
          <button class="btn btn-outline-dark btn-lg py-3 fw-bold">
            <i class="bi bi-heart me-2"></i>Add to Wishlist
          </button>
        </div>
      </div>
    </div>
  </div>

</body>
</html>