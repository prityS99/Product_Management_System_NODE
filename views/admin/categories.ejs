<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Category Management | FloraAdmin</title>
  
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <style>
    :root { --primary-color: #4e73df; --bg-color: #f8f9fc; }
    body { background-color: var(--bg-color); font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
    .card { border: none; border-radius: 0.75rem; box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.1); }
    .card-header { background-color: #f8f9fc; border-bottom: 1px solid #e3e6f0; font-weight: bold; color: var(--primary-color); }
    .btn-primary { background-color: var(--primary-color); border: none; }
    .table thead { background-color: #4e73df; color: white; }
    .badge-active { background-color: #1cc88a; color: white; }
  </style>
</head>
<body>

<div class="container py-5">
  
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/admin" class="text-decoration-none">Dashboard</a></li>
      <li class="breadcrumb-item active" aria-current="page">Categories</li>
    </ol>
  </nav>

  <div class="row g-4">
    
    <div class="col-lg-4">
      <div class="card">
        <div class="card-header py-3">
          <i class="fas fa-plus-circle me-2"></i>Add New Category
        </div>
        <div class="card-body">
          <form action="/admin/categories/add" method="POST">
            <div class="mb-3">
              <label for="name" class="form-label text-muted small fw-bold">CATEGORY NAME</label>
              <input 
                type="text" 
                class="form-control form-control-lg" 
                id="name" 
                name="name" 
                placeholder="e.g. Summer Collection" 
                required
              >
              <div class="form-text mt-2">A unique slug will be generated automatically.</div>
            </div>
            <button type="submit" class="btn btn-primary btn-lg w-100 mt-2">
              <i class="fas fa-save me-2"></i>Save Category
            </button>
          </form>
        </div>
      </div>
    </div>

    <div class="col-lg-8">
      <div class="card">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
          <span><i class="fas fa-list me-2"></i>Existing Categories</span>
          <span class="badge bg-primary text-white"><%= categories.length %> Total</span>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th class="ps-4">Category Name</th>
                  <th>Slug</th>
                  <th>Status</th>
                  <th class="text-center">Action</th>
                </tr>
              </thead>
              <tbody>
                <% if (categories && categories.length > 0) { %>
                  <% categories.forEach(item => { %>
                    <tr>
                      <td class="ps-4 fw-bold"><%= item.name %></td>
                      <td><code class="text-primary small">/<%= item.slug %></code></td>
                      <td><span class="badge badge-active">Active</span></td>
                      <td class="text-center">
                        <a href="/admin/categories/delete/<%= item._id %>" 
                           class="btn btn-sm btn-outline-danger"
                           onclick="return confirm('Delete this category?')">
                          <i class="fas fa-trash"></i>
                        </a>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="4" class="text-center py-5">
                      <img src="https://cdn-icons-png.flaticon.com/512/7486/7486744.png" width="60" class="mb-3 opacity-50" alt="Empty">
                      <p class="text-muted">No categories found in the database.</p>
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>