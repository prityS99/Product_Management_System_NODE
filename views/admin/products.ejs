<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Admin - Manage Products</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
  <style>
    .page-header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      border-radius: 1rem;
    }
    .card {
      transition: transform 0.2s ease;
    }
    .card:hover {
      transform: translateY(-5px);
    }
  </style>
</head>
<body class="bg-light">
  <div class="container py-5">
    
    <div class="page-header mb-5 py-4 px-4 d-flex justify-content-between align-items-center shadow">
      <div>
        <h1 class="fw-bold mb-1">Product Gallery</h1>
        <p class="mb-0 opacity-90">Showing your latest inventory</p>
      </div>
      <a href="/admin/products/add" class="btn btn-light fw-bold text-primary px-4">
        <i class="bi bi-plus-circle me-1"></i> Add New
      </a>
    </div>

    <div class="card shadow-sm mb-4 border-0">
      <div class="card-body p-3">
        <form method="GET" action="/admin/products" class="row g-2 align-items-center">
          <div class="col-md-3 col-12">
            <h6 class="mb-0 text-muted small">
              <i class="bi bi-funnel me-1"></i> Filter by category
            </h6>
          </div>

          <div class="col-md-5 col-8">
            <select name="category" class="form-select form-select-sm" onchange="this.form.submit()">
              <option value="">All Categories</option>
              <% categories.forEach(cat => { %>
                <option value="<%= cat._id %>" 
                  <%= (typeof selectedCategory !== 'undefined' && selectedCategory == cat._id.toString()) ? 'selected' : '' %>>
                  <%= cat.name %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="col-md-4 col-4 text-end">
            <a href="/admin/products" class="btn btn-sm btn-outline-secondary">
              <i class="bi bi-arrow-counterclockwise me-1"></i> Reset
            </a>
          </div>
        </form>
      </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
      <% if (products.length > 0) { %>
        <% products.forEach(product => { %>
          <div class="col">
            <div class="card h-100 shadow-sm border-0">
              
              <div class="position-relative">
                <img src="<%= product.image %>" 
                     class="card-img-top" 
                     alt="<%= product.name %>"
                     style="height: 220px; object-fit: cover;">
                
                <span class="position-absolute top-0 end-0 m-3 badge bg-info text-dark shadow-sm">
                  <%= product.categoryId ? product.categoryId.name : 'Uncategorized' %>
                </span>
              </div>

              <div class="card-body">
                <h5 class="card-title fw-bold mb-1"><%= product.name %></h5>
                <p class="text-muted small mb-1">Slug: <%= product.slug %></p>
                <p class="fw-bold text-success mb-3">₹<%= product.price %></p>
                
                <div class="d-flex gap-2">
                  <a href="/admin/products/edit/<%= product._id %>" class="btn btn-sm btn-outline-primary flex-grow-1">
                    <i class="bi bi-pencil-square"></i> Edit
                  </a>
                  
                  <a href="/admin/products/delete/<%= product._id %>" 
                     class="btn btn-sm btn-outline-danger flex-grow-1" 
                     onclick="return confirm('Delete this product permanently?')">
                    <i class="bi bi-trash"></i> Delete
                  </a>
                </div>
              </div>

            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="col-12 text-center py-5">
          <i class="bi bi-box-seam display-1 text-muted d-block mb-3"></i>
          <h3 class="text-muted">No products found</h3>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>